-- =====================
--   CLICK-TO-ADD LOGIC
-- =====================
local function visibleWallBetween(fromPos, toPos)
    local direction = toPos - fromPos
    local exclude = {}
    if localPlayer.Character then
        table.insert(exclude, localPlayer.Character)
    end
    local maxIterations = 30
    local currentOrigin = fromPos
    for _ = 1, maxIterations do
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        params.FilterDescendantsInstances = exclude
        local result = workspace:Raycast(currentOrigin, direction, params)
        if not result then return false end
        local hit = result.Instance
        local hitDist = (result.Position - fromPos).Magnitude
        local totalDist = direction.Magnitude
        if hitDist >= totalDist - 0.5 then return false end
        local isCharPart = false
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Character and hit:IsDescendantOf(player.Character) then
                isCharPart = true
                break
            end
        end
        if isCharPart then
            table.insert(exclude, hit)
            currentOrigin = result.Position + direction.Unit * 0.01
        elseif hit.Transparency >= 1 then
            table.insert(exclude, hit)
            currentOrigin = result.Position + direction.Unit * 0.01
        else
            return true
        end
    end
    return false
end

local function getClosestPlayerToScreen(screenPos)
    local closest = nil
    local closestDist = math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
                      or player.Character:FindFirstChild("Head")
            if root then
                local screenPoint, _ = camera:WorldToScreenPoint(root.Position)
                local dx = screenPoint.X - screenPos.X
                local dy = screenPoint.Y - screenPos.Y
                local dist = math.sqrt(dx*dx + dy*dy)
                if dist < closestDist then
                    closestDist = dist
                    closest = player
                end
            end
        end
    end
    if closestDist > 120 then return nil end
    if not closest or not closest.Character then return nil end
    if isFriend(closest) or isTarget(closest) then return closest end
    local root = closest.Character:FindFirstChild("HumanoidRootPart")
              or closest.Character:FindFirstChild("Head")
    if root and visibleWallBetween(camera.CFrame.Position, root.Position) then
        return nil
    end
    return closest
end

local function handleClickAdd(screenPos)
    if not clickMode then return end
    local player = getClosestPlayerToScreen(screenPos)
    if not player then return end
    local name = player.Name:lower()
    if clickMode == "target" then
        if isTarget(player) then
            targetsList = removeFromList(targetsList, player)
        elseif isFriend(player) then
            return
        else
            targetsList = addExactToList(targetsList, name)
        end
        if targetsBox then targetsBox.Text = table.concat(targetsList, " ") end
    elseif clickMode == "friend" then
        if isFriend(player) then
            friendsList = removeFromList(friendsList, player)
        elseif isTarget(player) then
            return
        else
            friendsList = addExactToList(friendsList, name)
        end
        if friendsBox then friendsBox.Text = table.concat(friendsList, " ") end
    end
    saveConfig()
    refreshAllHighlights()
end

