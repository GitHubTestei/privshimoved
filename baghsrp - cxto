-- =====================
--   FIGHT ZONE CHECK
-- =====================
local function isInFightZone(character)
    local zoneTrigger = workspace:FindFirstChild("Map")
        and workspace.Map:FindFirstChild("Building")
        and workspace.Map.Building:FindFirstChild("Building")
        and workspace.Map.Building.Building:FindFirstChild("FightZone")
        and workspace.Map.Building.Building.FightZone:FindFirstChild("ZoneTrigger")
    if not zoneTrigger then return false end
    if not character or not character:FindFirstChild("HumanoidRootPart") then return false end
    local rel = character.HumanoidRootPart.Position - zoneTrigger.Position
    local s = zoneTrigger.Size
    return math.abs(rel.X) <= s.X/2 and math.abs(rel.Y) <= s.Y/2 and math.abs(rel.Z) <= s.Z/2
end

