local CONFIG_FILE = "aura_gui_config.json"

local function saveConfig()
    if not writefile then return end
    local data = {
        keybinds = {
            killAura       = keybinds.killAura       and keybinds.killAura.Name       or "None",
            autoBlock      = keybinds.autoBlock      and keybinds.autoBlock.Name      or "None",
            deathTP        = keybinds.deathTP        and keybinds.deathTP.Name        or "None",
            distAura       = keybinds.distAura       and keybinds.distAura.Name       or "None",
            hitbox         = keybinds.hitbox         and keybinds.hitbox.Name         or "None",
            clickAddTarget = keybinds.clickAddTarget and keybinds.clickAddTarget.Name or "None",
            clickAddFriend = keybinds.clickAddFriend and keybinds.clickAddFriend.Name or "None",
        },
        friends = table.concat(friendsList, " "),
    }
    writefile(CONFIG_FILE, HttpService:JSONEncode(data))
end

local function splitWords(str)
    local words = {}
    for w in str:gmatch("%S+") do
        table.insert(words, w:lower())
    end
    return words
end

local function loadConfig()
    if not (readfile and isfile) then return end
    if not isfile(CONFIG_FILE) then return end
    local ok, data = pcall(function()
        return HttpService:JSONDecode(readfile(CONFIG_FILE))
    end)
    if not ok or not data then return end
    if data.keybinds then
        for k, name in pairs(data.keybinds) do
            if keybinds[k] ~= nil or true then
                if name ~= "None" and keybinds[k] == nil then
                    local ok2, kc = pcall(function() return Enum.KeyCode[name] end)
                    if ok2 and kc then keybinds[k] = kc end
                end
            end
        end
    end
    if data.friends and data.friends ~= "" then friendsList = splitWords(data.friends) end
end

loadConfig()

-- =====================
--   NAME MATCHING
-- =====================
local function matchesPartial(player, partial)
    local u = player.Name:lower()
    local d = player.DisplayName:lower()
    return u:find(partial, 1, true) ~= nil or d:find(partial, 1, true) ~= nil
end

local function isFriend(player)
    for _, p in ipairs(friendsList) do
        if matchesPartial(player, p) then return true end
    end
    return false
end

local function isTarget(player)
    for _, p in ipairs(targetsList) do
        if matchesPartial(player, p) then return true end
    end
    return false
end

-- =====================
--   LIST HELPERS
-- =====================
local function removeFromList(list, player)
    local newList = {}
    for _, partial in ipairs(list) do
        if not matchesPartial(player, partial) then
            table.insert(newList, partial)
        end
    end
    return newList
end

local function addExactToList(list, name)
    for _, v in ipairs(list) do
        if v == name then return list end
    end
    local new = {}
    for _, v in ipairs(list) do table.insert(new, v) end
    table.insert(new, name)
    return new
end

-- =====================
--   HIGHLIGHT SYSTEM
-- =====================
local function removeHighlight(player)
    if highlights[player] then
        highlights[player]:Destroy()
        highlights[player] = nil
    end
end

local function applyHighlight(player)
    if not player.Character then return end
    removeHighlight(player)
    local isFriendP = isFriend(player)
    local isTargetP = isTarget(player)
    if not isFriendP and not isTargetP then return end
    local h = Instance.new("Highlight")
    h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    h.FillTransparency = 0.90
    h.OutlineTransparency = 0.5
    if isFriendP then
        h.FillColor    = Color3.fromRGB(50, 255, 80)
        h.OutlineColor = Color3.fromRGB(50, 255, 80)
    else
        h.FillColor    = Color3.fromRGB(255, 50, 50)
        h.OutlineColor = Color3.fromRGB(255, 50, 50)
    end
    h.Adornee = player.Character
    h.Parent  = player.Character
    highlights[player] = h
end

local function refreshAllHighlights()
    for player in pairs(highlights) do removeHighlight(player) end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer then applyHighlight(player) end
    end
end

