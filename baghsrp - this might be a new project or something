--  AUTO-SAVE
-- ────────────────────────────────────────────────
local function SaveFriends(str)
    print("VOID_SAVE_FRIENDS:" .. str)
end

local function LoadFriends()
    local logs = LogService:GetLogHistory()
    for i = #logs, 1, -1 do
        local msg = logs[i].message
        if msg:find("VOID_SAVE_FRIENDS:") then
            return msg:split("VOID_SAVE_FRIENDS:")[2]
        end
    end
    return ""
end

Features.Friends = LoadFriends()

-- ────────────────────────────────────────────────
--  FRIEND CHECK
-- ────────────────────────────────────────────────
local function IsWhitelisted(plr)
    if Features.Friends == "" then return false end
    local names = string.split(string.lower(Features.Friends), " ")
    local targetUser = string.lower(plr.Name)
    local targetDisplay = string.lower(plr.DisplayName)
    for _, name in pairs(names) do
        if name ~= "" and (targetUser:find(name) or targetDisplay:find(name)) then
            return true
        end
    end
    return false
end

