local _arc_safeCFrame = CFrame.new(-502.844818, 11.1868954, -65.4427567)
local _arc_conn, _arc_platConn, _arc_platform, _arc_platformHB, _arc_origCF, _arc_returnTask
local _arc_inReturn, _arc_wasGrabbed, _arc_cleaned = false, false, false

local function arc_removePlatform()
    if _arc_platformHB then _arc_platformHB:Disconnect() _arc_platformHB = nil end
    if _arc_platform then pcall(_arc_platform.Destroy, _arc_platform) _arc_platform = nil end
end

local function arc_spawnPlatform(pos)
    arc_removePlatform()
    local model = Instance.new("Model", workspace)
    model.Name = "AntiRagSafe"
    _arc_platform = model
    local fy = pos.Y - 3.5
    local function box(cf,sz)
        local p = Instance.new("Part", model)
        p.Size=sz p.CFrame=cf p.Anchored=true p.CanCollide=true p.Transparency=0.7 p.Color=getAccent()
    end
    box(CFrame.new(pos.X,fy-0.5,pos.Z), Vector3.new(16,1,16))
    _arc_platformHB = RunService.Heartbeat:Connect(function()
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Position.Y < fy then hrp.CFrame = CFrame.new(pos.X, fy + 3.5, pos.Z) hrp.AssemblyLinearVelocity = Vector3.zero end
    end)
end

local function arc_forceEndRagdoll(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false; hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    for _,o in char:GetDescendants() do if o:IsA("Motor6D") then o.Enabled = true end end
end

local function arc_onCharacter(char)
    local hrp = char:WaitForChild("HumanoidRootPart",8)
    local hum = char:WaitForChild("Humanoid",8)
    if not hrp or not hum then return end
    task.wait(2.2)
    _arc_platConn = hum:GetPropertyChangedSignal("PlatformStand"):Connect(function()
        if not Features.AntiRag or _arc_inReturn then return end
        if hum.PlatformStand then _arc_wasGrabbed = true _arc_origCF = hrp.CFrame end
    end)
    _arc_conn = RunService.Heartbeat:Connect(function()
        if not Features.AntiRag or not char.Parent then return end
        if _arc_inReturn then return end
        local total, disabled = 0,0
        for _,v in char:GetDescendants() do if v:IsA("Motor6D") then total+=1 if not v.Enabled then disabled+=1 end end end
        if total >= 12 and disabled/total >= 0.9 then
            if not _arc_origCF then _arc_origCF = hrp.CFrame end
            if _arc_wasGrabbed then
                if not _arc_cleaned then arc_forceEndRagdoll(char) _arc_cleaned = true end
                if not _arc_returnTask then
                    _arc_inReturn = true
                    local saved = _arc_origCF
                    arc_spawnPlatform(_arc_safeCFrame.Position)
                    hrp.CFrame = _arc_safeCFrame
                    _arc_returnTask = task.delay(3.0, function()
                        arc_removePlatform()
                        if hrp.Parent and saved then hrp.CFrame = saved end
                        _arc_origCF = nil; _arc_returnTask = nil; _arc_inReturn = false; _arc_wasGrabbed = false; _arc_cleaned = false
                    end)
                end
            else
                hrp.CFrame = _arc_safeCFrame
                if not _arc_cleaned then arc_forceEndRagdoll(char) _arc_cleaned = true end
            end
        else
            if not _arc_wasGrabbed and _arc_origCF and not _arc_returnTask then
                _arc_inReturn = true
                local saved = _arc_origCF
                _arc_returnTask = task.delay(0, function()
                    if hrp.Parent and saved then hrp.CFrame = saved end
                    _arc_origCF = nil; _arc_returnTask = nil; _arc_inReturn = false; _arc_wasGrabbed = false; _arc_cleaned = false
                end)
            end
        end
    end)
end

