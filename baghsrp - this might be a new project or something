local friendHighlights = {}
local targetHighlight = nil
local tracerBeam = nil
local tracerAtt0 = nil
local tracerAtt1 = nil

local function UpdateVisuals(currentTarget)
    local pulse = 0.4 + ((math.sin(tick() * 10) + 1) / 2 * 0.3)

    if currentTarget and Features.KillAura then

        if not targetHighlight or targetHighlight.Adornee ~= currentTarget then
            if targetHighlight then targetHighlight:Destroy() end
            targetHighlight = Instance.new("Highlight")
            targetHighlight.FillColor = getAccent()
            targetHighlight.OutlineColor = Color3.new(1,1,1)
            targetHighlight.Adornee = currentTarget
            targetHighlight.Parent = currentTarget

            if tracerBeam then tracerBeam:Destroy() tracerBeam = nil end
            if tracerAtt0 then tracerAtt0:Destroy() tracerAtt0 = nil end
            if tracerAtt1 then tracerAtt1:Destroy() tracerAtt1 = nil end

            local char = LocalPlayer.Character
            local localRoot = char and char:FindFirstChild("HumanoidRootPart")
            local targetRoot = currentTarget:FindFirstChild("HumanoidRootPart")
            if localRoot and targetRoot then
                tracerAtt0 = Instance.new("Attachment", localRoot)
                tracerAtt1 = Instance.new("Attachment", targetRoot)
                tracerBeam = Instance.new("Beam", workspace.Terrain)
                tracerBeam.Attachment0 = tracerAtt0
                tracerBeam.Attachment1 = tracerAtt1
                tracerBeam.Width0 = 0.08
                tracerBeam.Width1 = 0.08
                tracerBeam.FaceCamera = true
                tracerBeam.Segments = 1
                tracerBeam.LightEmission = 1
            end
        end

        targetHighlight.FillColor = getAccent()
        targetHighlight.FillTransparency = pulse

        if tracerBeam then
            local accent = getAccent()
            tracerBeam.Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, Color3.new(1,1,1)),
                ColorSequenceKeypoint.new(0.1, accent),
                ColorSequenceKeypoint.new(0.9, accent),
                ColorSequenceKeypoint.new(1, Color3.new(1,1,1)),
            })
            tracerBeam.Transparency = NumberSequence.new(pulse - 0.3)
        end

    elseif targetHighlight then
        targetHighlight:Destroy()
        targetHighlight = nil
        if tracerBeam then tracerBeam:Destroy() tracerBeam = nil end
        if tracerAtt0 then tracerAtt0:Destroy() tracerAtt0 = nil end
        if tracerAtt1 then tracerAtt1:Destroy() tracerAtt1 = nil end
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and IsWhitelisted(plr) and plr.Character then
            if not friendHighlights[plr] or friendHighlights[plr].Adornee ~= plr.Character then
                if friendHighlights[plr] then friendHighlights[plr]:Destroy() end
                local h = Instance.new("Highlight")
                h.FillColor = FRIEND_COLOR
                h.OutlineColor = Color3.new(1,1,1)
                h.Adornee = plr.Character
                h.Parent = plr.Character
                friendHighlights[plr] = h
            end
            friendHighlights[plr].FillTransparency = pulse
        elseif friendHighlights[plr] then
            friendHighlights[plr]:Destroy()
            friendHighlights[plr] = nil
        end
    end
end

