        distRingPart = nil
    end
end

local function createRing()
    destroyRing()
    local part = Instance.new("Part")
    part.Name = "DistModeRing"
    part.Shape = Enum.PartType.Cylinder
    part.Anchored = true
    part.CanCollide = false
    part.CanQuery = false
    part.CastShadow = false
    part.Transparency = 0.3
    part.Material = Enum.Material.Neon
    part.Color = Color3.fromRGB(60, 120, 255)
    local r = math.max(distModeRadius + 3.5, 5)
    part.Size = Vector3.new(0.15, r * 2, r * 2)
    part.Parent = workspace
    distRingPart = part
    return part
end

local function updateRingSize()
    if distRingPart then
        local r = math.max(distModeRadius + 3.5, 5)
        distRingPart.Size = Vector3.new(0.15, r * 2, r * 2)
    end
end

