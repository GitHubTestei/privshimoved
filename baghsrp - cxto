    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = labelText
    nameLabel.TextColor3 = Color3.fromRGB(160, 180, 200)
    nameLabel.TextSize = 9
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Parent = row

    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0.4, 0, 0, 13)
    valLabel.BackgroundTransparency = 1
    valLabel.TextColor3 = Color3.fromRGB(230, 230, 230)
    valLabel.TextSize = 9
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    valLabel.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 22)
    track.BackgroundColor3 = Color3.fromRGB(30, 40, 55)
    track.BorderSizePixel = 0
    track.Active = true
    track.Parent = row
    Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(160, 160, 190)
    fill.BorderSizePixel = 0
    fill.Parent = track
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 14, 0, 14)
    thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position = UDim2.new(0, 0, 0.5, 0)
    thumb.BackgroundColor3 = Color3.fromRGB(230, 230, 230)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 3
    thumb.Active = true
    thumb.Parent = track
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    local divider = Instance.new("Frame")
    divider.Size = UDim2.new(1, 0, 0, 1)
    divider.Position = UDim2.new(0, 0, 1, -1)
    divider.BackgroundColor3 = Color3.fromRGB(18, 28, 38)
    divider.BorderSizePixel = 0
    divider.Parent = row

    local currentVal = defaultVal
    local sliding = false

    local function formatVal(v)
        if isInt then
            return tostring(math.floor(v + 0.5)) .. unit
        else
            return string.format("%.1f", v) .. unit
        end
    end

    local function setVal(v)
        v = math.clamp(v, minVal, maxVal)
        if isInt then v = math.floor(v + 0.5) end
        currentVal = v
        local pct = (v - minVal) / (maxVal - minVal)
        fill.Size = UDim2.new(pct, 0, 1, 0)
        thumb.Position = UDim2.new(pct, 0, 0.5, 0)
        valLabel.Text = formatVal(v)
        onChange(v)
    end

    local function handlePos(inputPos)
        local tp = track.AbsolutePosition
        local ts = track.AbsoluteSize
        local x = math.clamp(inputPos.X - tp.X, 0, ts.X)
        local pct = x / ts.X
        setVal(minVal + pct * (maxVal - minVal))
    end

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
            handlePos(Vector2.new(input.Position.X, input.Position.Y))
        end
    end)
    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            sliding = true
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not sliding then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            handlePos(Vector2.new(input.Position.X, input.Position.Y))
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            sliding = false
        end
    end)

    setVal(defaultVal)
    return function() return currentVal end
end

